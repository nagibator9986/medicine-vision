# ============================================================
# MediPlatform — Environment Configuration
# ============================================================
# Скопируйте этот файл как .env и заполните значения:
#   cp .env-example .env
# ============================================================

# Секретный ключ Flask (обязательно замените в продакшене!)
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-random-secret-key

# База данных (по умолчанию SQLite, для продакшена — PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/mediplatform

# OpenAI API Key — для AI-чатбота и транскрипций видеоконсультаций
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Разрешённые origins для WebSocket (через запятую)
# CORS_ORIGINS=http://localhost:5050,https://yourdomain.kz
